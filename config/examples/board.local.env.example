# Board connection
RKVOICE_BOARD_HOST=169.254.46.2
RKVOICE_BOARD_USERNAME=root
RKVOICE_BOARD_PASSWORD=change-me

# Optional local source address for link-local direct connection
RKVOICE_SOURCE_IP=169.254.46.223

# Optional board discovery settings
TTS_TSHARK_PATH=C:\workspace\apps\Wireshark\tshark.exe
TTS_ADAPTER_NAME=
TTS_HOSTNAME_HINT=RK3588
TTS_STATIC_CIDR=169.254.46.2/16
TTS_DISCOVERY_TIMEOUT=120
TTS_SSH_TIMEOUT=8
TTS_VERIFY_TIMEOUT=40

# Note
# Command line arguments override process environment variables.
# Process environment variables override config/local/*.env.
# board.local.env 是唯一受支持的本地板卡连接配置文件。