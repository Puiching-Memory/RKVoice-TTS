# ASR (sherpa-onnx) artifact paths
RKVOICE_STAGE_DIR=
RKVOICE_RUNTIME_DIR=
RKVOICE_REMOTE_DIR=/root/rkvoice/rkvoice_runtime

# TTS (MeloTTS-RKNN2) artifact paths
RKVOICE_MELO_STAGE_DIR=
RKVOICE_MELO_RUNTIME_DIR=
RKVOICE_MELO_REMOTE_DIR=/root/rkvoice/rkvoice_runtime
RKVOICE_MELO_TTS_TEXT=你好，欢迎使用离线语音合成服务。

# Board deployment settings
RKVOICE_REMOTE_TIMEOUT=1800

# Optional Toolkit2 host-side profiling settings
RKVOICE_TOOLKIT2_TARGET=rk3588
RKVOICE_TOOLKIT2_DEVICE_ID=
RKVOICE_TOOLKIT2_ADB_CONNECT=
RKVOICE_TOOLKIT2_ADB_SERIAL=

# Note
# Board SSH host, username, password and optional source IP should be placed in board.local.env.
# Unified runtime root uses RKVOICE_RUNTIME_DIR / RKVOICE_REMOTE_DIR.
# TTS delivery keeps RKVOICE_MELO_* names for stage assets and optional overrides.