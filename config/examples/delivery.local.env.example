# Local artifact paths
RKVOICE_STAGE_DIR=
RKVOICE_RUNTIME_DIR=

# Board deployment settings
RKVOICE_REMOTE_DIR=/root/rkvoice/sherpa_onnx_rk3588_runtime
RKVOICE_TTS_TEXT=你好，欢迎使用 RKVoice sherpa-onnx 离线语音服务。
RKVOICE_REMOTE_TIMEOUT=1800

# Note
# Board SSH host, username, password and optional source IP should be placed in board.local.env.
# New delivery defaults use RKVOICE_* names. Older TTS_* variables are still accepted for transition.