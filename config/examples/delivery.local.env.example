# Local build and runtime paths
TTS_STAGE_DIR=
TTS_RUNTIME_DIR=

# Docker build settings
TTS_DOCKER_IMAGE=ubuntu:22.04
TTS_DOCKER_BUILDER_IMAGE=
TTS_DOCKER_PLATFORM=linux/amd64
TTS_DOCKER_TIMEOUT=7200

# Board deployment settings
TTS_REMOTE_DIR=/root/tts/paddlespeech_tts_armlinux_runtime
TTS_SENTENCE=你好，欢迎使用离线语音合成服务。
TTS_REMOTE_TIMEOUT=1800

# Note
# Board SSH host, username, password and optional source IP should be placed in board.local.env.